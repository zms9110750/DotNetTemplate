<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>WinExe</OutputType>
    <ProjectType>gui</ProjectType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Auto-generated GUI sample</Description>
  </PropertyGroup>

  <PropertyGroup>
    <UseDI>true</UseDI>
    <DefineConstants>$(DefineConstants);IS_GUI</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PhotinoX.Blazor" Version="4.3.2" />
    <PackageReference Include="Masa.Blazor" Version="1.11.9" />
  </ItemGroup>

  <Target Name="CheckPhotinoFramework" BeforeTargets="CoreCompile"
          Condition="'$(TargetFramework)' != 'net8.0' And '$(TargetFramework)' != 'net9.0' And '$(TargetFramework)' != 'net10.0'">
    <Error Text="PhotinoX.Blazor 当前仅支持 net8.0/net9.0/net10.0。当前目标: $(TargetFramework)。请调整 TargetFramework 或更新 PhotinoX.Blazor。" />
  </Target>

  <ItemGroup>
    <Content Update="wwwroot\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="'$(IsLib)' == 'true'">
    <ProjectReference Include="..\..\src\MyApp\MyApp.csproj" />
  </ItemGroup>

</Project>
