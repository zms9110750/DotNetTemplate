<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>WinExe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>$(Authors).$([System.String]::Copy('$(MSBuildProjectName)').Replace(' ','_'))</RootNamespace>
    <AssemblyName>$(Authors).$(MSBuildProjectName)</AssemblyName>
    <Description>Auto-generated GUI sample (no-lib mode)</Description>
  </PropertyGroup>

  <PropertyGroup>
    <UseDI>true</UseDI>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PhotinoX.Blazor" Version="4.3.2" />
    <PackageReference Include="Masa.Blazor" Version="1.11.9" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="wwwroot\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <Target Name="CheckPhotinoFramework" BeforeTargets="CoreCompile"
          Condition="'$(TargetFramework)' != 'net8.0' And '$(TargetFramework)' != 'net9.0' And '$(TargetFramework)' != 'net10.0'">
    <Error Text="PhotinoX.Blazor 当前仅支持 net8.0/net9.0/net10.0。当前目标: $(TargetFramework)。请调整 TargetFramework 或更新 PhotinoX.Blazor。" />
  </Target>

</Project>

