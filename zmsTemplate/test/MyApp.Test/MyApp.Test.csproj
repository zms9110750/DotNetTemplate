<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>$(Authors).$([System.String]::Copy('$(MSBuildProjectName)').Replace(' ','_'))</RootNamespace>
    <AssemblyName>$(Authors).$(MSBuildProjectName)</AssemblyName>
    <Description>Auto-generated test project</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.8.1" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" />
  </ItemGroup>

  <ItemGroup Condition="'$(IsLib)' == 'true'">
    <ProjectReference Include="..\..\src\MyApp\MyApp.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsLib)' != 'true' And '$(IsCli)' == 'true'">
    <ProjectReference Include="..\..\src\MyApp.Cli\MyApp.Cli.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsLib)' != 'true' And '$(IsGui)' == 'true'">
    <ProjectReference Include="..\..\src\MyApp.GUI\MyApp.GUI.csproj" />
  </ItemGroup>

</Project>
