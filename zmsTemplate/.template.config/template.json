{
  "$schema": "http://json.schemastore.org/template",
  "author": "zms9110750",
  "classifications": [ "Console", "Library", "Test" ],
  "name": "JMComic 式项目模板",
  "description": "类库 + CLI/GUI 示例 + 测试，参考 JMComic 结构",
  "identity": "JMComicTemplate",
  "shortName": "jm",
  "sourceName": "MyApp",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },

  "symbols": {
    "IsLib":  { "type": "parameter", "description": "类库 (src)",             "datatype": "bool", "defaultValue": "false" },
    "IsCli":  { "type": "parameter", "description": "CLI 示例 (samples/CLI)", "datatype": "bool", "defaultValue": "false" },
    "IsGui":  { "type": "parameter", "description": "GUI 示例 (samples/GUI)", "datatype": "bool", "defaultValue": "false" },
    "IsTest": { "type": "parameter", "description": "测试 (test)",            "datatype": "bool", "defaultValue": "false" },

    "AuthorName": {
      "type": "parameter",
      "description": "作者名",
      "datatype": "text",
      "defaultValue": "zms9110750",
      "replaces": "{{AuthorName}}"
    },

    "UsePolly":       { "type": "parameter", "description": "Polly 弹性/重试",        "datatype": "bool", "defaultValue": "false" },
    "UseFusionCache": { "type": "parameter", "description": "FusionCache 缓存",       "datatype": "bool", "defaultValue": "false" },
    "UseDI":          { "type": "parameter", "description": "DI 依赖注入容器",         "datatype": "bool", "defaultValue": "false" },
    "UseLog":         { "type": "parameter", "description": "Serilog 日志",            "datatype": "bool", "defaultValue": "false" }
  },

  "sources": [
    {
      "modifiers": [
        // 默认排除所有
        { "condition": "true", "exclude": [
          "src/**/*",
          "samples/**/*",
          "test/**/*"
        ] },
        // lib 始终进 src
        { "condition": "(IsLib == true)", "include": [ "src/MyApp/**/*" ] },
        // lib 开 + cli 开 → CLI 进 samples（引用 lib）
        { "condition": "(IsLib == true && IsCli == true)", "include": [ "samples/MyApp.Cli/**/*" ] },
        // lib 开 + gui 开 → GUI 进 samples（引用 lib）
        { "condition": "(IsLib == true && IsGui == true)", "include": [ "samples/MyApp.GUI/**/*" ] },
        // lib 关 + cli 开 → CLI 进 src（无 lib）
        { "condition": "(IsLib == false && IsCli == true)", "include": [ "src/MyApp.Cli/**/*" ] },
        // lib 关 + gui 开 → GUI 进 src（无 lib）
        { "condition": "(IsLib == false && IsGui == true)", "include": [ "src/MyApp.GUI/**/*" ] },
        // test 始终进 test
        { "condition": "(IsTest == true)", "include": [ "test/**/*" ] }
      ]
    }
  ],

  "postActions": [
    {
      "description": "还原 NuGet 包",
      "actionId": "B175A520-76F8-46F5-800C-2B55B8A0E65F",
      "args": { "noRestore": "false" },
      "manualInstructions": [ { "text": "手动 dotnet restore" } ],
      "continueOnError": true
    }
  ]
}
