{
  "$schema": "http://json.schemastore.org/template",
  "author": "zms9110750",
  "classifications": [ "Console", "Library", "Test" ],
  "name": "开源项目模板",
  "description": "类库 + CLI/GUI 示例 + 测试的完整解决方案模板",
  "identity": "OpenSourceProjectTemplate",
  "shortName": "jm",
  "sourceName": "MyApp",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },

  "symbols": {
    "TIsLib":  { "type": "parameter", "description": "类库 (src)",             "datatype": "bool", "defaultValue": "false", "replaces": "{{TIsLib}}" },
    "TIsCli":  { "type": "parameter", "description": "CLI 示例 (samples/CLI)", "datatype": "bool", "defaultValue": "false", "replaces": "{{TIsCli}}" },
    "TIsGui":  { "type": "parameter", "description": "GUI 示例 (samples/GUI)", "datatype": "bool", "defaultValue": "false", "replaces": "{{TIsGui}}" },
    "TIsTest": { "type": "parameter", "description": "测试 (test)",            "datatype": "bool", "defaultValue": "false", "replaces": "{{TIsTest}}" },

    "AuthorName": {
      "type": "parameter",
      "description": "作者名",
      "datatype": "text",
      "defaultValue": "",
      "replaces": "{{AuthorName}}"
    },

    "TUsePolly":       { "type": "parameter", "description": "Polly 弹性/重试",        "datatype": "bool", "defaultValue": "false", "replaces": "{{TUsePolly}}" },
    "TUseFusionCache": { "type": "parameter", "description": "FusionCache 缓存",       "datatype": "bool", "defaultValue": "false", "replaces": "{{TUseFusionCache}}" },
    "TUseDI":          { "type": "parameter", "description": "DI 依赖注入容器",         "datatype": "bool", "defaultValue": "false", "replaces": "{{TUseDI}}" },
    "TUseLog":         { "type": "parameter", "description": "Serilog 日志",            "datatype": "bool", "defaultValue": "false", "replaces": "{{TUseLog}}" }
  },

  "sources": [
    {
      "copyOnly": [ "**/Global.cs" ],
      "modifiers": [
        // 默认排除所有
        { "condition": "true", "exclude": [
          "src/**/*",
          "samples/**/*",
          "test/**/*"
        ] },
        // lib 始终进 src
        { "condition": "(TIsLib == true)", "include": [ "src/MyApp/**/*" ], "copyOnly": [ "**/Global.cs" ] },
        // lib 开 + cli 开 → CLI 进 samples（引用 lib）
        { "condition": "(TIsLib == true && TIsCli == true)", "include": [ "samples/MyApp.Cli/**/*" ], "copyOnly": [ "**/Global.cs" ] },
        // lib 开 + gui 开 → GUI 进 samples（引用 lib）
        { "condition": "(TIsLib == true && TIsGui == true)", "include": [ "samples/MyApp.GUI/**/*" ], "copyOnly": [ "**/Global.cs" ] },
        // lib 关 + cli 开 → CLI 进 src（无 lib）
        { "condition": "(TIsLib == false && TIsCli == true)", "include": [ "src/MyApp.Cli/**/*" ], "copyOnly": [ "**/Global.cs" ] },
        // lib 关 + gui 开 → GUI 进 src（无 lib）
        { "condition": "(TIsLib == false && TIsGui == true)", "include": [ "src/MyApp.GUI/**/*" ], "copyOnly": [ "**/Global.cs" ] },
        // test 始终进 test
        { "condition": "(TIsTest == true)", "include": [ "test/**/*" ], "copyOnly": [ "**/Global.cs" ] }
      ]
    }
  ],

  "specialCustomOperations": {
    "**/*.md": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "//#if" ],
            "else": [ "//#else" ],
            "elseif": [ "//#elseif" ],
            "endif": [ "//#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    }
  },

  "postActions": [
    {
      "description": "还原 NuGet 包",
      "actionId": "B175A520-76F8-46F5-800C-2B55B8A0E65F",
      "args": { "noRestore": "false" },
      "manualInstructions": [ { "text": "手动 dotnet restore" } ],
      "continueOnError": true
    }
  ]
}
